{
  "name": "temp-app",
  "private": true,
  "version": "1.0.0",
  "description": "Full-Stack Learning Management System with AI-powered note summarization",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "install:all": "npm install && cd backend && npm install",
    "start": "node scripts/start-dev.cjs",
    "setup": "npm run install:all && npm run init-db",
    "init-db": "cd backend && node -e \"require('./database-sqlite').initializeDatabase()\"",
    "test": "echo \"Tests not implemented yet\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "lucide-react": "^0.575.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^8.2.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.3.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/studybuddy.git"
  },
  "keywords": [
    "react",
    "nodejs",
    "express",
    "sqlite",
    "jwt",
    "ai",
    "learning-management",
    "full-stack"
  ],
  "author": "Your Name",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
